{
  "name": "yasumaro",
  "version": "6.6.1",
  "description": "Log your browsing history with AI summaries into local SQLite storage. Optional Obsidian integration.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "node scripts/check-version-consistency.js && wxt build",
    "build:store": "node scripts/check-version-consistency.js && wxt build && node scripts/build-store-zip.mjs",
    "build:docs-i18n": "node scripts/sync-docs-translations.mjs",
    "build:docs-pii": "esbuild docs-src/pii-sandbox.ts --bundle --outfile=docs/assets/pii-sandbox.js --format=iife --global-name=PiiSandbox",
    "build:edge": "node scripts/check-version-consistency.js && wxt build --browser edge && node scripts/build-store-zip.mjs",
    "build:brave": "node scripts/check-version-consistency.js && wxt build && node scripts/build-store-zip.mjs",
    "build:watch": "wxt build --watch",
    "update-preset": "node --loader ts-node/esm scripts/update-preset-domains.ts",
    "update-manifest": "npx ts-node scripts/update-manifest-from-preset.ts",
    "update-tranco": "npm run update-preset && npm run update-manifest",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config testDir/playwright.config.ts",
    "test:e2e:ui": "playwright test --config testDir/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config testDir/playwright.config.ts --debug",
    "test:e2e:headed": "playwright test --config testDir/playwright.config.ts --headed",
    "test:e2e:ci": "xvfb-run --auto-servernum --server-args='-screen 0 1280x960x24' playwright test --config testDir/playwright.config.ts --grep @extension",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "type-check:test": "tsc --project testDir/tsconfig.json --noEmit",
    "test:type-safe": "npm run type-check:test && npm test",
    "lint": "eslint .",
    "lint:adr-links": "node scripts/lint-adr-links.mjs",
    "validate": "npm run type-check && npm test",
    "docs": "typedoc --options dev-docs/typedoc.json",
    "docs:watch": "typedoc --options dev-docs/typedoc.json --watch",
    "clean": "rm -rf dist",
    "capture:store-screenshots": "node scripts/capture-store-screenshots.mjs",
    "check-htmlparser2": "node scripts/check-htmlparser2-override.js",
    "check-bundle-size": "node scripts/check-bundle-size.mjs",
    "generate-notices": "node scripts/generate-third-party-notices.mjs",
    "check-licenses": "node scripts/check-licenses.mjs"
  },
  "keywords": [
    "obsidian",
    "chrome-extension",
    "browser-history",
    "ai-summary"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@peculiar/webcrypto": "^1.5.0",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^4.1.4",
    "adm-zip": "^0.6.0",
    "crx3": "^2.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "happy-dom": "^20.11.1",
    "jsdom": "^29.0.0",
    "knip": "^6.29.0",
    "license-checker": "^25.0.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.4",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "@subframe7536/sqlite-wasm": "~1.3.1",
    "wa-sqlite": "~1.0.0"
  },
  "overrides": {
    "adm-zip": "^0.6.0",
    "htmlparser2": "~12.0.0",
    "shell-quote": ">=1.10.0",
    "tmp": ">=0.2.6",
    "uuid": "^11.1.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
